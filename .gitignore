# --- Data & model artifacts (these live on Great Lakes, never commit them) ---
# We ignore by FILE TYPE so the folder structure (the .gitkeep files) stays tracked,
# but no actual image / tensor / checkpoint data ever gets committed.
*.nii
*.nii.gz
*.img
*.hdr
*.mnc
*.npy
*.npz
*.pt
*.pth
*.h5
_inspect/

# --- Python ---
__pycache__/
*.pyc
.ipynb_checkpoints/
.venv/
env/

# --- OS / editor / secrets ---
.DS_Store
Thumbs.db
.env
.env.local
